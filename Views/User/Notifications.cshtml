@model List<EcoRecycle.Models.Notification>
@{
    ViewData["Title"] = "My Notifications";
}

<div class="row py-4">
    <div class="col-lg-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold m-0 text-success-emphasis"><i class="bi bi-bell-fill me-2"></i>My Notifications</h2>
                <p class="text-secondary m-0">Stay updated on your pickup statuses, reward redemptions, and campaigns.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Dashboard</a>
        </div>

        <div class="glass-card p-4 shadow-sm">
            @if (Model != null && Model.Count > 0)
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var n in Model)
                    {
                        var icon = "bi-bell";
                        var bgClass = "bg-secondary-subtle text-secondary-emphasis";

                        if (n.Type == "PickupAccepted") { icon = "bi-truck"; bgClass = "bg-primary-subtle text-primary-emphasis"; }
                        else if (n.Type == "PickupScheduled") { icon = "bi-calendar-date"; bgClass = "bg-info-subtle text-info-emphasis"; }
                        else if (n.Type == "PickupCompleted") { icon = "bi-check-circle"; bgClass = "bg-success-subtle text-success-emphasis"; }
                        else if (n.Type == "PickupRejected") { icon = "bi-x-circle"; bgClass = "bg-danger-subtle text-danger-emphasis"; }
                        else if (n.Type == "RewardEarned") { icon = "bi-gift"; bgClass = "bg-warning-subtle text-warning-emphasis"; }
                        else if (n.Type == "CampaignStarted") { icon = "bi-globe-americas"; bgClass = "bg-success-subtle text-success-emphasis"; }

                        <div class="p-3 border rounded-4 bg-body-tertiary d-flex align-items-start gap-3 @(n.IsRead ? "opacity-75" : "border-success border-2 shadow-sm")">
                            <div class="rounded-circle p-2 d-flex align-items-center justify-content-center @bgClass" style="width: 42px; height: 42px; flex-shrink: 0;">
                                <i class="bi @icon fs-5"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="badge @bgClass" style="font-size: 0.7rem;">@n.Type</span>
                                    <small class="text-secondary">@n.CreatedAt.ToString("MMM dd, yyyy t")</small>
                                </div>
                                <p class="m-0 text-secondary-emphasis">@n.Message</p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-secondary">
                    <i class="bi bi-bell-slash fs-1"></i>
                    <p class="mt-2">You don't have any notifications at the moment.</p>
                </div>
            }
        </div>
    </div>
</div>
