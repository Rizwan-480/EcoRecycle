@model Dictionary<string, string>
@{
    ViewData["Title"] = "System Settings";
    
    // Retrieve values safely
    string googleMapsKey = Model.ContainsKey("GoogleMapsApiKey") ? Model["GoogleMapsApiKey"] : "";
    string huggingFaceKey = Model.ContainsKey("HuggingFaceApiKey") ? Model["HuggingFaceApiKey"] : "";
    bool localMapsFallback = Model.ContainsKey("LocalMapsFallback") && Model["LocalMapsFallback"] == "True";
}

<div class="row py-4">
    <div class="col-lg-8 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold m-0 text-success-emphasis"><i class="bi bi-sliders me-2"></i>System Configuration Settings</h2>
                <p class="text-secondary m-0">Configure API endpoints, map providers, and local fallbacks.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Dashboard</a>
        </div>

        <div class="glass-card p-4 p-md-5 shadow-sm">
            <form asp-action="Settings" method="post">
                @Html.AntiForgeryToken()
                
                <h5 class="fw-bold text-success border-bottom pb-2 mb-4"><i class="bi bi-map me-2"></i>Map Provider API Configuration</h5>
                
                <div class="mb-3">
                    <label for="googleMapsInput" class="form-label fw-semibold">Google Maps API Key</label>
                    <input type="text" name="googleMapsKey" id="googleMapsInput" value="@googleMapsKey" class="form-control" placeholder="Enter Google Maps API key" />
                    <small class="text-secondary d-block mt-1">If left blank, the application will automatically fall back to **OpenStreetMap using Leaflet.js** (recommending free, zero-key configuration).</small>
                </div>

                <div class="mb-4 form-check">
                    <input type="checkbox" name="localMapsFallback" value="true" class="form-check-input" id="fallbackCheck" @(localMapsFallback ? "checked" : "") />
                    <input type="hidden" name="localMapsFallback" value="false" />
                    <label class="form-check-label text-secondary small" for="fallbackCheck">Enable OpenStreetMap/Leaflet.js automatic fallback</label>
                </div>

                <h5 class="fw-bold text-success border-bottom pb-2 mb-4 mt-5"><i class="bi bi-cpu me-2"></i>AI Waste Classification Configuration</h5>
                
                <div class="mb-4">
                    <label for="hfKeyInput" class="form-label fw-semibold">Hugging Face Inference API Key</label>
                    <input type="password" name="huggingFaceKey" id="hfKeyInput" value="@huggingFaceKey" class="form-control" placeholder="Enter Hugging Face Token (hf_...)" />
                    <small class="text-secondary d-block mt-1">Provide a Hugging Face User Access Token to run classification requests against the live ResNet-50 endpoint. If left empty, the application runs a local keyword matching classification engine.</small>
                </div>

                <button type="submit" class="btn btn-eco btn-lg rounded-pill px-5 py-3 mt-3"><i class="bi bi-check-circle me-1"></i> Save Configuration</button>
            </form>
        </div>
    </div>
</div>
