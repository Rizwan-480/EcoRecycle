@model List<EcoRecycle.Models.User>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="row py-4">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold m-0 text-success-emphasis"><i class="bi bi-people me-2"></i>User Accounts Administration</h2>
            <p class="text-secondary m-0">Review system user profiles, check points balance, and manage system access.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Dashboard</a>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="glass-card p-4 shadow-sm">
            @if (Model != null && Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle m-0">
                        <thead>
                            <tr>
                                <th>Name / Username</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Reward Points</th>
                                <th>Date Registered</th>
                                <th>Status</th>
                                <th class="text-end">Access Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(u.AvatarUrl) && u.AvatarUrl != "/images/default-avatar.png")
                                            {
                                                <img src="@u.AvatarUrl" class="rounded-circle" style="width: 38px; height: 38px; object-fit: cover;" alt="Avatar" />
                                            }
                                            else
                                            {
                                                var firstLetter = u.FullName.Trim().Length > 0 ? u.FullName.Trim().Substring(0, 1).ToUpper() : "?";
                                                <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold" style="width: 38px; height: 38px; font-size: 15px;">
                                                    @firstLetter
                                                </div>
                                            }
                                            <div>
                                                <strong class="text-primary-emphasis d-block">@u.FullName</strong>
                                                <small class="text-secondary">@@@u.Username</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@u.Email</td>
                                    <td>
                                        <span class="badge @(u.RoleName == "Admin" ? "bg-danger" : u.RoleName == "RecyclingStore" ? "bg-primary" : "bg-success") rounded-pill px-3 py-1">
                                            @u.RoleName
                                        </span>
                                    </td>
                                    <td>
                                        <strong class="text-success">@u.RewardPoints pts</strong>
                                    </td>
                                    <td>
                                        <small class="text-secondary">@u.CreatedAt.ToString("MMM dd, yyyy")</small>
                                    </td>
                                    <td>
                                        <span class="badge @(u.IsBlocked ? "bg-danger" : "bg-success") px-2 py-1" id="status-badge-@u.UserID">
                                            @(u.IsBlocked ? "Suspended" : "Active")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        @if (u.RoleName != "Admin")
                                        {
                                            <button class="btn btn-sm btn-block-toggle @(u.IsBlocked ? "btn-outline-success" : "btn-outline-danger") rounded-pill px-3" data-id="@u.UserID" data-blocked="@(u.IsBlocked ? "true" : "false")">
                                                @(u.IsBlocked ? "Restore Access" : "Block User")
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">System protected</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-secondary text-center py-5">No user accounts found in the database.</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toggleButtons = document.querySelectorAll(".btn-block-toggle");
            toggleButtons.forEach(btn => {
                btn.addEventListener("click", function () {
                    const userId = btn.dataset.id;
                    const currentlyBlocked = btn.dataset.blocked === "true";
                    const targetBlockedState = !currentlyBlocked;
                    const confirmMsg = targetBlockedState 
                        ? "Are you sure you want to suspend this user's account?" 
                        : "Are you sure you want to restore access for this user?";
                    
                    if (!confirm(confirmMsg)) return;

                    btn.disabled = true;

                    // Execute block AJAX
                    fetch(`/Admin/ToggleBlockUser?id=${userId}&isBlocked=${targetBlockedState}`, {
                        method: 'POST'
                    })
                    .then(response => response.json())
                    .then(data => {
                        btn.disabled = false;
                        if (data.success) {
                            showToastNotification(data.message, "success");
                            
                            // Update badge
                            const badge = document.getElementById(`status-badge-${userId}`);
                            if (badge) {
                                badge.innerText = targetBlockedState ? "Suspended" : "Active";
                                badge.className = targetBlockedState ? "badge bg-danger" : "badge bg-success";
                            }
                            
                            // Update button
                            btn.dataset.blocked = targetBlockedState ? "true" : "false";
                            btn.className = targetBlockedState ? "btn btn-sm btn-block-toggle btn-outline-success rounded-pill px-3" : "btn btn-sm btn-block-toggle btn-outline-danger rounded-pill px-3";
                            btn.innerText = targetBlockedState ? "Restore Access" : "Block User";
                        } else {
                            showToastNotification(data.message, "error");
                        }
                    })
                    .catch(err => {
                        btn.disabled = false;
                        showToastNotification("Failed to toggle block status.", "error");
                        console.error(err);
                    });
                });
            });
        });
    </script>
}
