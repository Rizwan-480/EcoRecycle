@model List<EcoRecycle.Models.WasteCategory>
@{
    ViewData["Title"] = "Waste Categories";
}

<div class="row py-4">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold m-0 text-success-emphasis"><i class="bi bi-diagram-3-fill me-2"></i>Waste Categories Manager</h2>
            <p class="text-secondary m-0">Define recycling materials, set reward multipliers, and adjust active statuses.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-success rounded-pill px-4" id="btnAddCategory"><i class="bi bi-plus-lg me-1"></i> Add Category</button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3 d-flex align-items-center"><i class="bi bi-arrow-left me-1"></i> Back</a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="glass-card p-4 shadow-sm">
            @if (Model != null && Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle m-0">
                        <thead>
                            <tr>
                                <th>Category Details</th>
                                <th>Rate (Points/Kg)</th>
                                <th>Icon CSS</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="btn-eco rounded-circle p-2 d-flex align-items-center justify-content-center text-white" style="width: 38px; height: 38px;">
                                                <i class="@(c.IconUrl ?? "bi-recycle") fs-5"></i>
                                            </div>
                                            <div>
                                                <strong class="text-primary-emphasis d-block">@c.Name</strong>
                                                <small class="text-secondary">@c.Description</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-success-subtle text-success border border-success-subtle fs-6 rounded-pill px-3">
                                            @c.PointsPerKg pts
                                        </span>
                                    </td>
                                    <td><code>@(c.IconUrl ?? "bi-recycle")</code></td>
                                    <td>
                                        <span class="badge @(c.IsRecyclable ? "bg-success" : "bg-secondary")">
                                            @(c.IsRecyclable ? "Recyclable" : "Non-Recyclable")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 btn-edit-cat" data-id="@c.CategoryID" data-name="@c.Name" data-desc="@c.Description" data-rate="@c.PointsPerKg" data-icon="@c.IconUrl" data-recyclable="@(c.IsRecyclable ? "true" : "false")">
                                            Edit
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal: Category Add/Edit -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <form asp-action="SaveCategory" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold text-success-emphasis" id="categoryModalLabel">Add Category</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" name="categoryId" id="catIdInput" value="0" />

                    <div class="mb-3">
                        <label for="catNameInput" class="form-label fw-semibold">Category Name</label>
                        <input type="text" name="name" id="catNameInput" class="form-control" placeholder="e.g. Aluminum cans" required />
                    </div>

                    <div class="mb-3">
                        <label for="catDescInput" class="form-label fw-semibold">Description</label>
                        <input type="text" name="description" id="catDescInput" class="form-control" placeholder="e.g. Soda cans, food tins" />
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="catRateInput" class="form-label fw-semibold">Multiplier (pts/Kg)</label>
                            <input type="number" name="pointsPerKg" id="catRateInput" class="form-control" min="0" required />
                        </div>
                        <div class="col-md-6">
                            <label for="catIconInput" class="form-label fw-semibold">Bootstrap Icon Class</label>
                            <input type="text" name="iconUrl" id="catIconInput" class="form-control" placeholder="e.g. bi-nut" />
                        </div>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" name="isRecyclable" value="true" class="form-check-input" id="catRecyclableCheck" checked />
                        <input type="hidden" name="isRecyclable" value="false" />
                        <label class="form-check-label text-secondary small" for="catRecyclableCheck">Is Recyclable and Incentive Active</label>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success rounded-pill px-4">Save Category</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modalEl = document.getElementById("categoryModal");
            const modal = new bootstrap.Modal(modalEl);
            const modalTitle = document.getElementById("categoryModalLabel");
            
            // Form inputs
            const catId = document.getElementById("catIdInput");
            const catName = document.getElementById("catNameInput");
            const catDesc = document.getElementById("catDescInput");
            const catRate = document.getElementById("catRateInput");
            const catIcon = document.getElementById("catIconInput");
            const catCheck = document.getElementById("catRecyclableCheck");

            // Add Category trigger
            document.getElementById("btnAddCategory").addEventListener("click", function () {
                modalTitle.innerText = "Add Waste Category";
                catId.value = "0";
                catName.value = "";
                catDesc.value = "";
                catRate.value = "10";
                catIcon.value = "bi-recycle";
                catCheck.checked = true;
                modal.show();
            });

            // Edit Category trigger
            const editButtons = document.querySelectorAll(".btn-edit-cat");
            editButtons.forEach(btn => {
                btn.addEventListener("click", function () {
                    modalTitle.innerText = "Edit Waste Category";
                    catId.value = btn.dataset.id;
                    catName.value = btn.dataset.name;
                    catDesc.value = btn.dataset.desc;
                    catRate.value = btn.dataset.rate;
                    catIcon.value = btn.dataset.icon;
                    catCheck.checked = btn.dataset.recyclable === "true";
                    modal.show();
                });
            });
        });
    </script>
}
