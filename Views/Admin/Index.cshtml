@model EcoRecycle.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-12">
        <h2 class="fw-bold m-0"><i class="bi bi-shield-lock text-success me-2"></i>Administration Dashboard</h2>
        <p class="text-secondary m-0">Platform overview, system controls, store approvals, and recycling analytics.</p>
    </div>
</div>

<!-- Quick Widgets -->
<div class="row g-4 mb-5">
    <div class="col-md-2 col-sm-4 col-6">
        <div class="glass-card text-center p-3 h-100 bg-success-subtle text-success-emphasis border border-success-subtle">
            <span class="small text-secondary d-block">Users</span>
            <strong class="fs-2 fw-extrabold text-success">@Model.TotalUsers</strong>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-6">
        <div class="glass-card text-center p-3 h-100 bg-primary-subtle text-primary-emphasis border border-primary-subtle">
            <span class="small text-secondary d-block">Stores</span>
            <strong class="fs-2 fw-extrabold text-primary">@Model.TotalStores</strong>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-6">
        <div class="glass-card text-center p-3 h-100 bg-warning-subtle text-warning-emphasis border border-warning-subtle">
            <span class="small text-secondary d-block">Pending Stores</span>
            <strong class="fs-2 fw-extrabold text-warning">@Model.PendingStores</strong>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-6">
        <div class="glass-card text-center p-3 h-100 bg-info-subtle text-info-emphasis border border-info-subtle">
            <span class="small text-secondary d-block">Total Pickups</span>
            <strong class="fs-2 fw-extrabold text-info">@Model.TotalPickups</strong>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-6">
        <div class="glass-card text-center p-3 h-100 bg-success-subtle text-success-emphasis border border-success-subtle">
            <span class="small text-secondary d-block">Completed</span>
            <strong class="fs-2 fw-extrabold text-success">@Model.CompletedPickups</strong>
        </div>
    </div>
    <div class="col-md-2 col-sm-4 col-6">
        <div class="glass-card text-center p-3 h-100 bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">
            <span class="small text-secondary d-block">Pending</span>
            <strong class="fs-2 fw-extrabold text-secondary">@Model.PendingPickups</strong>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Chart: Waste Category Weights -->
    <div class="col-lg-6">
        <div class="glass-card p-4 shadow-sm h-100">
            <h5 class="fw-bold mb-4 text-success-emphasis"><i class="bi bi-bar-chart-line me-2"></i>Waste Collected by Category (Kg)</h5>
            <div class="chart-container">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Chart: Monthly Collection Trends -->
    <div class="col-lg-6">
        <div class="glass-card p-4 shadow-sm h-100">
            <h5 class="fw-bold mb-4 text-success-emphasis"><i class="bi bi-graph-up-arrow me-2"></i>Monthly Collection Trend</h5>
            <div class="chart-container">
                <canvas id="monthlyChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Quick action shortcuts -->
    <div class="col-12 text-center">
        <h5 class="fw-bold mb-4 text-secondary-emphasis"><i class="bi bi-gear-fill me-2"></i>Quick Administrative Actions</h5>
        <div class="d-flex justify-content-center flex-wrap gap-3">
            <a asp-action="Stores" class="btn btn-outline-success rounded-pill px-4 py-2"><i class="bi bi-patch-check me-1"></i> Approve Stores (@Model.PendingStores)</a>
            <a asp-action="Verification" class="btn btn-outline-success rounded-pill px-4 py-2"><i class="bi bi-qr-code-scan me-1"></i> QR Code Verification</a>
            <a asp-action="Campaigns" class="btn btn-outline-success rounded-pill px-4 py-2"><i class="bi bi-calendar-event me-1"></i> Create Campaigns</a>
            <a asp-action="Settings" class="btn btn-outline-success rounded-pill px-4 py-2"><i class="bi bi-sliders me-1"></i> Edit Settings</a>
            <a asp-action="AuditLogs" class="btn btn-outline-success rounded-pill px-4 py-2"><i class="bi bi-journal-text me-1"></i> Audit Logs</a>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Category Stats Data
            const catLabels = [];
            const catData = [];
            @foreach (var stat in Model.CategoryStats)
            {
                <text>
                catLabels.push("@stat.CategoryName");
                catData.push(parseFloat("@stat.TotalWeight"));
                </text>
            }

            // Render Category weights chart
            const ctxCat = document.getElementById('categoryChart').getContext('2d');
            new Chart(ctxCat, {
                type: 'doughnut',
                data: {
                    labels: catLabels,
                    datasets: [{
                        data: catData,
                        backgroundColor: [
                            '#198754', // Plastic
                            '#0dcaf0', // Paper
                            '#fd7e14', // Glass
                            '#adb5bd', // Metal
                            '#6f42c1', // Electronics
                            '#20c997', // Organic
                            '#6c757d'  // Unknown
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });

            // Monthly stats Data
            const monthLabels = [];
            const monthPickups = [];
            const monthWeights = [];
            @foreach (var stat in Model.MonthlyStats)
            {
                <text>
                monthLabels.push("@stat.MonthLabel");
                monthPickups.push(parseInt("@stat.TotalPickups"));
                monthWeights.push(parseFloat("@stat.TotalWeight"));
                </text>
            }

            // Render monthly trend chart
            const ctxMonth = document.getElementById('monthlyChart').getContext('2d');
            new Chart(ctxMonth, {
                type: 'bar',
                data: {
                    labels: monthLabels,
                    datasets: [
                        {
                            label: 'Total Weight (Kg)',
                            data: monthWeights,
                            backgroundColor: 'rgba(25, 135, 84, 0.7)',
                            borderColor: '#198754',
                            borderWidth: 1,
                            yAxisID: 'y'
                        },
                        {
                            label: 'Pickups Count',
                            data: monthPickups,
                            type: 'line',
                            borderColor: '#0d6efd',
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            tension: 0.3,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: {
                                display: true,
                                text: 'Weight (Kg)'
                            }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            grid: {
                                drawOnChartArea: false
                            },
                            title: {
                                display: true,
                                text: 'Pickups Count'
                            }
                        }
                    }
                }
            });
        });
    </script>
}
