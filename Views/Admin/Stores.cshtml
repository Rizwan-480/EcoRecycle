@{
    ViewData["Title"] = "Store Approvals";
    var pending = ViewBag.Pending as List<EcoRecycle.Models.Store>;
    var approved = ViewBag.Approved as List<EcoRecycle.Models.Store>;
}

<div class="row py-4">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold m-0 text-success-emphasis"><i class="bi bi-patch-check me-2"></i>Recycling Store Approvals</h2>
            <p class="text-secondary m-0">Approve new store registrations or review active storefront locations on the platform.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Dashboard</a>
    </div>
</div>

<!-- Pending Approvals Section -->
<div class="row mb-5">
    <div class="col-12">
        <div class="glass-card p-4 shadow-sm border-warning-subtle">
            <h5 class="fw-bold text-warning-emphasis border-bottom pb-2 mb-4"><i class="bi bi-clock-history me-2"></i>Pending Approvals Queue (@(pending?.Count ?? 0))</h5>
            
            @if (pending != null && pending.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle m-0">
                        <thead>
                            <tr>
                                <th>Store Details</th>
                                <th>Address</th>
                                <th>Operating Hours</th>
                                <th>Owner Details</th>
                                <th class="text-end">Approval Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in pending)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-primary-emphasis d-block">@s.StoreName</strong>
                                        <small class="text-secondary">Tel: @(s.ContactNumber ?? "N/A")</small>
                                    </td>
                                    <td>
                                        <span class="text-truncate-2 d-inline-block small" style="max-width: 250px;">@s.StoreAddress</span>
                                    </td>
                                    <td>@s.OperatingHours</td>
                                    <td>
                                        <span class="d-block fw-semibold text-dark-emphasis">@s.OwnerFullName</span>
                                        <small class="text-secondary">@s.OwnerEmail</small>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <form asp-action="ApproveStore" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="storeId" value="@s.StoreID" />
                                                <input type="hidden" name="approve" value="true" />
                                                <button type="submit" class="btn btn-sm btn-success rounded-pill px-3"><i class="bi bi-check2"></i> Approve</button>
                                            </form>
                                            <form asp-action="ApproveStore" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="storeId" value="@s.StoreID" />
                                                <input type="hidden" name="approve" value="false" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"><i class="bi bi-x-lg"></i> Reject</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-secondary text-center py-4">No store registration requests are currently pending approval.</p>
            }
        </div>
    </div>
</div>

<!-- Active Storefronts Section -->
<div class="row">
    <div class="col-12">
        <div class="glass-card p-4 shadow-sm">
            <h5 class="fw-bold text-success-emphasis border-bottom pb-2 mb-4"><i class="bi bi-check-all me-2"></i>Active approved Stores (@(approved?.Count ?? 0))</h5>
            
            @if (approved != null && approved.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle m-0">
                        <thead>
                            <tr>
                                <th>Store Name</th>
                                <th>Address</th>
                                <th>Operating Hours</th>
                                <th>Owner</th>
                                <th>Coordinates</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in approved)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-primary-emphasis d-block">@s.StoreName</strong>
                                        <small class="text-secondary">Tel: @(s.ContactNumber ?? "N/A")</small>
                                    </td>
                                    <td>
                                        <span class="text-truncate-2 d-inline-block small" style="max-width: 250px;">@s.StoreAddress</span>
                                    </td>
                                    <td>@s.OperatingHours</td>
                                    <td>
                                        <span class="d-block fw-semibold text-dark-emphasis">@s.OwnerFullName</span>
                                        <small class="text-secondary">@s.OwnerEmail</small>
                                    </td>
                                    <td>
                                        <code class="small text-secondary">@s.Latitude.ToString("F4"), @s.Longitude.ToString("F4")</code>
                                    </td>
                                    <td class="text-end">
                                        <form asp-action="ApproveStore" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="storeId" value="@s.StoreID" />
                                            <input type="hidden" name="approve" value="false" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="return confirm('Suspend this store center registration?')"><i class="bi bi-slash-circle me-1"></i> Suspend Store</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-secondary text-center py-4">No active stores found on the platform.</p>
            }
        </div>
    </div>
</div>
