@model EcoRecycle.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "System Reports";
}

<div class="row py-4">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold m-0 text-success-emphasis"><i class="bi bi-file-earmark-bar-graph me-2"></i>Platform Reports & Analytics</h2>
            <p class="text-secondary m-0">Aggregate weights per category, monthly collections, and points statistics.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Dashboard</a>
    </div>
</div>

<div class="row g-4">
    <!-- Category Weights Table -->
    <div class="col-md-6">
        <div class="glass-card p-4 shadow-sm h-100">
            <h5 class="fw-bold text-success-emphasis border-bottom pb-2 mb-3"><i class="bi bi-table me-2"></i>Category Weight Totals</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle m-0">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th class="text-end">Total Weight Collected</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.CategoryStats)
                        {
                            <tr>
                                <td><strong class="text-primary-emphasis">@c.CategoryName</strong></td>
                                <td class="text-end fw-bold">@c.TotalWeight.ToString("N1") Kg</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Monthly Collection Summary -->
    <div class="col-md-6">
        <div class="glass-card p-4 shadow-sm h-100">
            <h5 class="fw-bold text-success-emphasis border-bottom pb-2 mb-3"><i class="bi bi-calendar-check-fill me-2"></i>Monthly Aggregates</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle m-0">
                    <thead>
                        <tr>
                            <th>Month</th>
                            <th class="text-center">Total Pickups</th>
                            <th class="text-end">Total Weight</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.MonthlyStats)
                        {
                            <tr>
                                <td><strong class="text-primary-emphasis">@m.MonthLabel</strong></td>
                                <td class="text-center">@m.TotalPickups</td>
                                <td class="text-end fw-bold text-success">@m.TotalWeight.ToString("N1") Kg</td>
                            </tr>
                        }
                        
                        @if (Model.MonthlyStats.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-secondary py-3">No monthly collection records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
