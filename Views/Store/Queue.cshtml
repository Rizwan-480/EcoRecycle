@model List<EcoRecycle.Models.PickupRequest>
@{
    ViewData["Title"] = "Pending Request Queue";
}

<div class="row py-4">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold m-0 text-success-emphasis"><i class="bi bi-collection me-2"></i>Pending Pickup Queue</h2>
            <p class="text-secondary m-0">Review pending pickup requests from nearby households and accept them to your schedule.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Back to Dashboard</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-10 mx-auto">
        <div class="glass-card p-4 shadow-sm">
            @if (Model != null && Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle m-0">
                        <thead>
                            <tr>
                                <th>Requested Date</th>
                                <th>Client Name</th>
                                <th>Collection Address</th>
                                <th>Instructions / Notes</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="d-block fw-semibold text-primary-emphasis">@p.CreatedAt.ToString("MMM dd, yyyy")</span>
                                        <small class="text-secondary">@p.CreatedAt.ToString("t")</small>
                                    </td>
                                    <td>
                                        <strong class="text-primary-emphasis">@p.UserFullName</strong>
                                    </td>
                                    <td>
                                        <span class="text-truncate-2 d-inline-block small" style="max-width: 250px;">@p.Address</span>
                                    </td>
                                    <td>
                                        <span class="text-truncate-2 d-inline-block text-secondary small" style="max-width: 200px;">@(p.Notes ?? "No instruction notes")</span>
                                    </td>
                                    <td class="text-end">
                                        <form asp-action="AcceptRequest" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@p.PickupID" />
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-4"><i class="bi bi-hand-thumbs-up me-1"></i> Accept Request</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-secondary">
                    <i class="bi bi-mailbox2 fs-1 text-success"></i>
                    <h5 class="fw-bold mt-3 text-dark-emphasis">Queue is Empty</h5>
                    <p class="small text-secondary">All community pickup requests have been claimed by local centers. Check back later!</p>
                </div>
            }
        </div>
    </div>
</div>
