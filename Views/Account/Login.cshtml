@model EcoRecycle.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="row align-items-center justify-content-center py-5">
    <div class="col-md-6 col-lg-5">
        <div class="glass-card p-4 p-md-5 border shadow">
            <div class="text-center mb-4">
                <i class="bi bi-recycle text-success display-4 mb-2 d-inline-block"></i>
                <h2 class="fw-bold">Welcome Back</h2>
                <p class="text-secondary">Sign in to your EcoRecycle account</p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                @Html.AntiForgeryToken()
                
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-body border-end-0"><i class="bi bi-envelope text-secondary"></i></span>
                        <input asp-for="Email" class="form-control border-start-0" placeholder="name@example.com" required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <label asp-for="Password" class="form-label fw-semibold">Password</label>
                        <a asp-action="ForgotPassword" class="text-success small fw-medium text-decoration-none">Forgot Password?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-body border-end-0"><i class="bi bi-lock text-secondary"></i></span>
                        <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="Enter your password" required />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check d-flex justify-content-between align-items-center">
                    <div>
                        <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberCheck">
                        <label class="form-check-label text-secondary small" for="rememberCheck">Remember this device</label>
                    </div>
                    <div>
                        <input type="checkbox" class="form-check-input" id="showPasswordLoginCheck">
                        <label class="form-check-label text-secondary small" for="showPasswordLoginCheck">Show Password</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-eco w-100 py-2 fs-6 mb-3">Sign In</button>

                <p class="text-center text-secondary small m-0">
                    Don't have an account? <a asp-action="Register" class="text-success fw-bold text-decoration-none">Join now</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simple client side validation check
        const forms = document.querySelectorAll('form');
        forms.forEach(form => {
            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });

        // Show/Hide password toggle
        const showPasswordLoginCheck = document.getElementById('showPasswordLoginCheck');
        const loginPasswordInput = document.getElementById('Password');
        if (showPasswordLoginCheck && loginPasswordInput) {
            showPasswordLoginCheck.addEventListener('change', function () {
                const type = this.checked ? 'text' : 'password';
                loginPasswordInput.setAttribute('type', type);
            });
        }
    </script>
}
