@model EcoRecycle.Models.News
@{
    ViewData["Title"] = Model.Title;
}

<div class="row py-4">
    <div class="col-lg-8 mx-auto">
        <a class="btn btn-outline-secondary btn-sm rounded-pill px-3 mb-4" asp-action="Index"><i class="bi bi-arrow-left me-1"></i> Back to Home</a>
        
        <div class="glass-card p-4 p-md-5">
            <div class="d-flex justify-content-between align-items-center mb-3 text-secondary">
                <span class="badge bg-success">News</span>
                <span>Published @Model.CreatedAt.ToString("MMMM dd, yyyy")</span>
            </div>

            <h1 class="fw-bold mb-4 text-primary-emphasis">@Model.Title</h1>

            <div class="py-5 bg-success text-center text-white rounded-4 mb-4">
                <i class="bi bi-globe-americas display-1"></i>
            </div>

            <div class="fs-5 text-secondary-emphasis" style="line-height: 1.8; white-space: pre-line;">
                @Model.Content
            </div>
        </div>
    </div>
</div>
